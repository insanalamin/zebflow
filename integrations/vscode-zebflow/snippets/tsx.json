{
  "TSX Page Module": {
    "prefix": "tsx-page",
    "body": [
      "export const page = {",
      "  head: {",
      "    title: \"${1:Hello Zebflow}\"",
      "  },",
      "  navigation: \"history\"",
      "};",
      "",
      "export const app = {",
      "  state: {",
      "    ui: { title: \"${1:Hello Zebflow}\", count: 0 }",
      "  },",
      "  actions: {",
      "    \"counter.inc\": (ctx) => {",
      "      const next = Number(ctx.get(\"ui.count\") || 0) + 1;",
      "      ctx.set(\"ui.count\", next);",
      "      return \"ui.count\";",
      "    }",
      "  }",
      "};",
      "",
      "export default function Page(input) {",
      "  return (",
      "    <Page>",
      "      <main className=\"p-6\">",
      "        <h1 jText=\"ui.title\">${2:Hello Zebflow}</h1>",
      "        <button onClick=\"counter.inc\" className=\"px-3 py-2 bg-black text-white rounded\">",
      "          Count: <span jText=\"ui.count\">0</span>",
      "        </button>",
      "      </main>",
      "    </Page>",
      "  );",
      "}"
    ],
    "description": "Create a Zebflow TSX page module using the current page contract."
  }
}

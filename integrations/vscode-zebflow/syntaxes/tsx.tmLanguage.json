{
  "name": "Zebflow TSX",
  "scopeName": "text.html.zebflow.tsx",
  "patterns": [
    {
      "begin": "(<)(script)(?=\\s|>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" }
      },
      "end": "(</)(script)(\\s*>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [
        { "include": "source.js" }
      ]
    },
    {
      "begin": "(<)(style)(?=\\s|>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.style.html" }
      },
      "end": "(</)(style)(\\s*>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.style.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [
        { "include": "source.css" }
      ]
    },
    { "include": "text.html.basic" }
  ]
}
